    "@types/node": "^22.15.3",
    "@types/qrcode": "^1.5.5",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.25.4",
    "tailwindcss": "^4.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "vite": "^6.3.2"
  }
