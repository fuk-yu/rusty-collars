# ESP32-P4-WiFi additions (layered on top of sdkconfig.defaults + sdkconfig.defaults.esp32p4)
#
# WiFi via companion ESP32-C6 (esp_hosted over SDIO)
# Tested on: Waveshare ESP32-P4-WIFI6-POE-ETH
# The companion C6 must be running the esp_hosted slave firmware.
#
# SDIO pinout (same as Espressif P4-Function-EV-Board):
#   CLK=GPIO18, CMD=GPIO19, D0=GPIO14, D1=GPIO15, D2=GPIO16, D3=GPIO17
#   Slave reset=GPIO54
#
# WARNING: GPIO14-19 are used by SDIO — do not assign LEDs or RF pins to these!

CONFIG_ESP_WIFI_REMOTE_ENABLED=y
CONFIG_ESP_WIFI_REMOTE_LIBRARY_HOSTED=y

# Companion chip target
CONFIG_SLAVE_IDF_TARGET_ESP32C6=y

# Board layout — Waveshare P4-WIFI6-POE-ETH uses same SDIO pinout as Espressif P4-Function-EV
CONFIG_ESP_HOSTED_P4_DEV_BOARD_FUNC_BOARD=y

# LWIP tuning for WiFi throughput
CONFIG_LWIP_TCP_SND_BUF_DEFAULT=65534
CONFIG_LWIP_TCP_WND_DEFAULT=65534
CONFIG_LWIP_TCP_RECVMBOX_SIZE=64
CONFIG_LWIP_UDP_RECVMBOX_SIZE=64
CONFIG_LWIP_TCPIP_RECVMBOX_SIZE=64
CONFIG_LWIP_TCP_SACK_OUT=y
